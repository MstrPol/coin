// Platform CI: bump semver → publish gp-content zip → register in coin-api.

pipeline {
    agent any

    parameters {
        choice(name: 'STACK', choices: ['go-app'], description: 'GP content stack')
        choice(name: 'BUMP', choices: ['patch', 'minor', 'major'], description: 'Semver bump от latest в coin-api')
    }

    environment {
        COIN_API_URL = 'http://coin-api:8090'
        NEXUS_URL = 'http://nexus:8081'
        NEXUS_MAVEN_RELEASES = 'maven-releases'
        NEXUS_MAVEN_SNAPSHOTS = 'maven-snapshots'
    }

    stages {
        stage('Resolve version') {
            steps {
                script {
                    def alloc = nextGPContentVersion(params.STACK, params.BUMP)
                    env.CONTENT_VERSION = alloc.nextVersion
                    if (alloc.isFirst) {
                        echo "==> gp-content/${params.STACK}: первая регистрация → ${alloc.nextVersion}"
                    } else {
                        echo "==> gp-content/${params.STACK}: ${alloc.currentVersion} + ${params.BUMP} → ${alloc.nextVersion}"
                    }
                }
            }
        }
        stage('Publish content') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-admin',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASSWORD',
                    ),
                    string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY'),
                ]) {
                    sh './scripts/publish-content.sh "${STACK}" "${CONTENT_VERSION}"'
                }
            }
        }
    }
}

@NonCPS
def parseNextContentVersionResponse(String json, String stack, String bump) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    return [
        name: stack,
        bump: bump,
        currentVersion: (parsed.currentVersion ?: '').toString(),
        nextVersion: parsed.nextVersion.toString(),
        isFirst: parsed.isFirst == true,
    ]
}

def nextGPContentVersion(stack, bump) {
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        def status = sh(
            script: """
                set +e
                code=\$(curl -s -o next-ver.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${env.COIN_API_URL}/v1/admin/components/gp-content/${stack}/next-version?bump=${bump}')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (status == '200') {
            return parseNextContentVersionResponse(readFile('next-ver.json'), stack, bump)
        }
        error("gp-content next-version HTTP ${status}")
    }
}
