{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schemas/gp-content.schema.json",
  "title": "GP content (content.yaml) v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "kind", "capabilities", "build", "pipeline", "artifacts"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "const": "gp-content"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deliverables"],
      "properties": {
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["image", "artifact"]
          }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["buildkit", "dockerfile"]
        },
        "buildkit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["targets", "cacheRefTemplate"],
          "properties": {
            "targets": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "string",
                "minLength": 1
              }
            },
            "cacheRefTemplate": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "dockerfile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "cacheRefTemplate"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "imageTarget": {
              "type": "string",
              "minLength": 1
            },
            "testTarget": {
              "type": "string",
              "minLength": 1
            },
            "cacheRefTemplate": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "engine": { "const": "buildkit" } },
            "required": ["engine"]
          },
          "then": { "required": ["buildkit"] }
        },
        {
          "if": {
            "properties": { "engine": { "const": "dockerfile" } },
            "required": ["engine"]
          },
          "then": { "required": ["dockerfile"] }
        }
      ]
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validateSchema"],
      "properties": {
        "validateSchema": {
          "type": "string",
          "minLength": 1
        },
        "containerfile": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
