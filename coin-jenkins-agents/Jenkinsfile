// Platform CI: сборка CI agent images → Nexus Docker → report version в coin-api.
// Параметр DOCKERFILE: agents/{stack}/{runtime}.Dockerfile
pipeline {
    agent any

    parameters {
        string(
            name: 'DOCKERFILE',
            defaultValue: 'agents/go/1.22.Dockerfile',
            description: 'Путь к Dockerfile (agents/{stack}/{runtime}.Dockerfile)',
        )
    }

    environment {
        COIN_API_URL = 'http://coin-api:8090'
        // push: host docker.sock → localhost; metadata для k3s pod → nexus
        COIN_REGISTRY_PREFIX = 'localhost:8082/coin-docker'
        COIN_REGISTRY_RUNTIME_PREFIX = 'nexus:8082/coin-docker'
        NEXUS_DOCKER_CREDENTIALS = 'nexus-docker'
    }

    stages {
        stage('Build agents') {
            steps {
                script {
                    buildOneAgent(params.DOCKERFILE.trim())
                }
            }
        }
    }
}

def parseAgentDockerfile(path) {
    def m = (path =~ /^agents\/([^\/]+)\/(.+)\.Dockerfile$/)
    if (!m.matches()) {
        error("DOCKERFILE должен быть agents/{stack}/{runtime}.Dockerfile, получено: ${path}")
    }
    return [stack: m.group(1), runtime: m.group(2)]
}

def imageRepoForStack(stack) {
    switch (stack) {
        case 'java-maven': return 'ci-jvm-maven'
        case 'java-gradle': return 'ci-jvm-gradle'
        default: return "ci-${stack}"
    }
}

@NonCPS
def parseNextVersionResponse(String json, String stack, String runtime) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    return [
        stack: stack,
        runtime: runtime,
        currentRev: (parsed.currentRev ?: 0) as int,
        nextRev: (parsed.nextRev ?: 1) as int,
        nextVersion: parsed.nextVersion.toString(),
    ]
}

@NonCPS
def maxAgentRevFromVersionsJson(String json, String runtime) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    def items = parsed.items ?: []
    def suffix = ~/^${java.util.regex.Pattern.quote(runtime)}-r(\d+)$/
    int maxRev = 0
    items.each { v ->
        def m = (v.version.toString() =~ suffix)
        if (m.matches()) {
            int n = m.group(1) as int
            if (n > maxRev) {
                maxRev = n
            }
        }
    }
    return maxRev
}

def agentAlloc(stack, runtime, int currentRev, int nextRev) {
    return [
        stack: stack,
        runtime: runtime,
        currentRev: currentRev,
        nextRev: nextRev,
        nextVersion: "${runtime}-r${nextRev}",
    ]
}

def nextAgentVersion(stack, runtime) {
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        def status = sh(
            script: """
                set +e
                code=\$(curl -s -o next-ver.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${env.COIN_API_URL}/v1/admin/components/agent/${stack}/next-version?runtime=${runtime}')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (status == '200') {
            return parseNextVersionResponse(readFile('next-ver.json'), stack, runtime)
        }

        // coin-api без /next-version (старый образ): считаем rev из списка версий или r1.
        def listStatus = sh(
            script: """
                set +e
                code=\$(curl -s -o versions.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${env.COIN_API_URL}/v1/admin/components/agent/${stack}/versions')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (listStatus != '200' && listStatus != '404') {
            error("next-version HTTP ${status}, list versions HTTP ${listStatus}")
        }

        int maxRev = 0
        if (listStatus == '200') {
            maxRev = maxAgentRevFromVersionsJson(readFile('versions.json'), runtime)
        }

        int nextRev = maxRev + 1
        echo "next-version fallback (coin-api HTTP ${status}): ${runtime}-r${nextRev}"
        return agentAlloc(stack, runtime, maxRev, nextRev)
    }
}

def buildOneAgent(dockerfile) {
    def parts = parseAgentDockerfile(dockerfile)
    def stack = parts.stack
    def runtime = parts.runtime

    if (!fileExists(dockerfile)) {
        error("Dockerfile не найден: ${dockerfile}")
    }

    def alloc = nextAgentVersion(stack, runtime)
    def tag = alloc.nextVersion
    def currentRev = alloc.currentRev
    echo "==> agent/${stack} ${runtime}: r${currentRev} → ${tag}"

    def pushRegistry = env.COIN_REGISTRY_PREFIX ?: 'localhost:8082/coin-docker'
    def runtimeRegistry = env.COIN_REGISTRY_RUNTIME_PREFIX ?: 'nexus:8082/coin-docker'
    def registryHost = pushRegistry.split('/')[0]
    def credId = env.NEXUS_DOCKER_CREDENTIALS ?: 'nexus-docker'
    def imageRepo = imageRepoForStack(stack)
    def pushRef = "${pushRegistry}/${imageRepo}:${tag}"
    def runtimeRef = "${runtimeRegistry}/${imageRepo}:${tag}"

    def goarch = sh(
        script: '''case "$(uname -m)" in
            arm64|aarch64) echo arm64 ;;
            x86_64|amd64) echo amd64 ;;
            *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
        esac''',
        returnStdout: true,
    ).trim()

    echo "==> ${dockerfile} → ${pushRef} (runtime ref: ${runtimeRef})"

    withCredentials([usernamePassword(
        credentialsId: credId,
        usernameVariable: 'REG_USER',
        passwordVariable: 'REG_PASS',
    )]) {
        sh """
            set -euo pipefail
            export DOCKER_CONFIG="\${WORKSPACE}/.docker"
            mkdir -p "\${WORKSPACE}/.docker"
            echo "\${REG_PASS}" | docker login '${registryHost}' -u "\${REG_USER}" --password-stdin
            docker build --platform 'linux/${goarch}' -f '${dockerfile}' -t '${pushRef}' .
            docker push '${pushRef}'
        """
    }

    def digest = sh(
        script: """
            set -euo pipefail
            rd=\$(docker inspect --format='{{index .RepoDigests 0}}' '${pushRef}' 2>/dev/null || true)
            if [[ "\${rd}" == *@sha256:* ]]; then
              echo "\${rd#*@}"
            fi
        """,
        returnStdout: true,
    ).trim()

    echo "digest=${digest}"
    reportAgentVersion(stack, runtime, tag, runtimeRef, digest)
}

def reportAgentVersion(stack, runtime, tag, ref, digest) {
    def payload = groovy.json.JsonOutput.toJson([
        version: tag,
        metadata: [
            image: ref,
            digest: digest,
            stack: stack,
            runtime: runtime,
        ],
        actor: 'jenkins-agents',
    ])
    writeFile file: 'agent-version.json', text: payload
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        sh """
            set -euo pipefail
            curl -sf -X POST '${env.COIN_API_URL}/v1/admin/components/agent/${stack}/versions' \\
              -H 'Content-Type: application/json' \\
              -H "X-API-Key: \${COIN_API_KEY}" \\
              -d @agent-version.json
        """
    }
}
