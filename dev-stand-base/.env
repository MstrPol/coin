# Общее
DOCKER_PLATFORM=linux/arm64

# Gitea — контейнер (GITEA__*) + хост
USER_UID=1000
USER_GID=1000
GITEA__repository__ROOT=/data/git/repositories
GITEA__server__DOMAIN=gitea
GITEA__server__HTTP_PORT=3000
GITEA__server__ROOT_URL=http://gitea:3000/
GITEA__server__DISABLE_SSH=true
GITEA__server__START_SSH_SERVER=false
GITEA__database__DB_TYPE=sqlite3
GITEA__database__PATH=/data/gitea/gitea.db
GITEA__security__INSTALL_LOCK=true
GITEA__security__SECRET_KEY=coin-local-gitea-secret-key-change-me
GITEA__service__DISABLE_REGISTRATION=true
GITEA__log__LEVEL=warn
GITEA_HTTP_PORT=3000
GITEA_USER=coin
GITEA_PASSWORD=coin
GITEA_EMAIL=coin@local

# Nexus
NEXUS_IMAGE_TAG=3.91.1-alpine
NEXUS_HTTP_PORT=8081
NEXUS_DOCKER_PORT=8082
NEXUS_DOCKER_REPO=coin-docker
NEXUS_DOCKER_CACHE_REPO=coin-cache
NEXUS_DOCKER_GROUP=coin-docker-group
NEXUS_MAVEN_RELEASES=maven-releases
NEXUS_MAVEN_SNAPSHOTS=maven-snapshots
NEXUS_ADMIN_PASSWORD=coin12345
NEXUS_DOCKER_USER=coin
NEXUS_DOCKER_PASSWORD=coin1234

# k3s
K3S_API_PORT=6443
K3S_DASHBOARD_PORT=8443

# Jenkins
JENKINS_HTTP_PORT=8080
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin
COIN_API_TOKEN=dev-local-token
COIN_PUBLISHER_API_KEY=dev-local-publisher-key
