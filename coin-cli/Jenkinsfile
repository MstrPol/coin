// Platform CI: coin CLI → Nexus Maven (zip, classifier linux-<arch>).
// Версия: coin-cli/VERSION (semver) + параметры job.
// Test/Build — K8s dynamic agent (ci-go из coin-platform/agents/catalog.yaml).
@Library('coin-lib') _

def goStackImage(catalog) {
    def entry = catalog.stacks?.go?.'1.22'
    if (!entry?.image) {
        error('agents/catalog.yaml: нет stacks.go.1.22')
    }
    def registry = catalog.registry?.default ?: 'nexus:8082/coin-docker'
    def tag = entry.tag ?: "1.22-r${entry.rev ?: 0}"
    return "${registry}/${entry.image}:${tag}"
}

def computeCliVersion(bump, snapshot) {
    return sh(
        script: """
            set -eu
            chmod +x scripts/compute-version.sh
            ./scripts/compute-version.sh VERSION '${bump}' '${snapshot ? 'true' : 'false'}'
        """,
        returnStdout: true,
    ).trim()
}

pipeline {
    agent none

    parameters {
        booleanParam(
            name: 'PUBLISH',
            defaultValue: false,
            description: 'Опубликовать zip в Nexus Maven',
        )
        booleanParam(
            name: 'SNAPSHOT',
            defaultValue: true,
            description: 'Snapshot (-SNAPSHOT → maven-snapshots). Снять для release.',
        )
        choice(
            name: 'VERSION_BUMP',
            choices: ['none', 'patch', 'minor', 'major'],
            description: 'Bump semver от coin-cli/VERSION (none — текущая база)',
        )
    }

    environment {
        MAVEN_GROUP = 'coin.platform'
        MAVEN_ARTIFACT = 'coin-cli'
        NEXUS_BASE = 'http://nexus:8081/repository'
        GIT_AUTHOR_EMAIL = 'jenkins@coin.local'
        GIT_AUTHOR_NAME = 'Jenkins'
    }

    stages {
        stage('Test & Build') {
            steps {
                script {
                    def stackImage
                    def jnlpImage
                    node('built-in') {
                        checkout scm
                        coinPlatformCheckout([:])
                        def catalog = readYaml file: "${env.COIN_PLATFORM_DIR}/agents/catalog.yaml"
                        def platform = readYaml file: "${env.COIN_PLATFORM_DIR}/platform.yaml"
                        stackImage = goStackImage(catalog)
                        jnlpImage = platform.jenkins?.jnlp?.image
                        if (!jnlpImage) {
                            error('platform.yaml: jenkins.jnlp.image не задан')
                        }
                        echo "coin-cli agent: ${stackImage}"
                    }

                    def podLabel = "coin-cli-${env.BUILD_NUMBER}"
                    def podYaml = coinPodTemplate(jnlpImage, stackImage)
                    podTemplate(yaml: podYaml, cloud: 'kubernetes', label: podLabel) {
                        node(podLabel) {
                            checkout scm
                            coinPlatformCheckout([:])
                            container('stack') {
                                env.COIN_CLI_VERSION = computeCliVersion(params.VERSION_BUMP, params.SNAPSHOT)
                                echo "coin-cli version: ${env.COIN_CLI_VERSION} (bump=${params.VERSION_BUMP}, snapshot=${params.SNAPSHOT})"
                                writeFile file: '.coin-cli-version', text: env.COIN_CLI_VERSION

                                sh 'go test ./...'
                                sh '''
                                    set -eu
                                    case "$(uname -m)" in
                                        arm64|aarch64) GOARCH=arm64 ;;
                                        x86_64|amd64) GOARCH=amd64 ;;
                                        *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                                    esac
                                    GOOS=linux CGO_ENABLED=0 GOARCH="${GOARCH}" go build \
                                      -buildvcs=false \
                                      -ldflags "-X coin.local/coin-cli/cmd.Version=${COIN_CLI_VERSION}" \
                                      -o coin .
                                    echo "${GOARCH}" > .goarch
                                '''
                                stash includes: 'coin,.goarch,.coin-cli-version', name: 'coin-binary'
                            }
                        }
                    }
                }
            }
        }

        stage('Publish Maven') {
            when {
                expression { params.PUBLISH }
            }
            agent { label 'built-in' }
            steps {
                checkout scm
                unstash 'coin-binary'
                script {
                    env.GOARCH = readFile('.goarch').trim()
                    env.COIN_CLI_VERSION = readFile('.coin-cli-version').trim()
                }
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-admin',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASSWORD',
                )]) {
                    sh '''
                        set -eu
                        ZIP="coin-cli-linux-${GOARCH}.zip"
                        zip -j "${ZIP}" coin

                        case "${COIN_CLI_VERSION}" in
                          *SNAPSHOT*) MAVEN_REPO=maven-snapshots ;;
                          *) MAVEN_REPO=maven-releases ;;
                        esac

                        GAV_PATH="$(echo "${MAVEN_GROUP}" | tr "." "/")/${MAVEN_ARTIFACT}/${COIN_CLI_VERSION}"
                        REMOTE="${NEXUS_BASE}/${MAVEN_REPO}/${GAV_PATH}/${MAVEN_ARTIFACT}-${COIN_CLI_VERSION}-linux-${GOARCH}.zip"
                        curl -f -S -u "${NEXUS_USER}:${NEXUS_PASSWORD}" \
                          -X PUT --upload-file "${ZIP}" "${REMOTE}"

                        echo "published ${REMOTE}"
                    '''
                }
            }
        }

        stage('Record VERSION') {
            when {
                expression { params.PUBLISH }
            }
            agent { label 'built-in' }
            steps {
                checkout scm
                unstash 'coin-binary'
                script {
                    def versionBase = readFile('.coin-cli-version').trim()
                    if (versionBase.endsWith('-SNAPSHOT')) {
                        versionBase = versionBase.replaceAll(/-SNAPSHOT$/, '')
                    }
                    writeFile file: 'VERSION', text: "${versionBase}\n"
                    withCredentials([usernamePassword(
                        credentialsId: 'gitea-git',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS',
                    )]) {
                        sh """
                            set -eu
                            export HOME=/var/jenkins_home
                            git config user.email '${env.GIT_AUTHOR_EMAIL}'
                            git config user.name '${env.GIT_AUTHOR_NAME}'
                            git add VERSION
                            git diff --staged --quiet && echo 'VERSION unchanged, skip commit' && exit 0
                            git commit -m 'chore(coin-cli): VERSION ${versionBase} [skip ci]'
                            git push "http://\${GIT_USER}:\${GIT_PASS}@gitea:3000/coin/coin-cli.git" HEAD:main
                        """
                    }
                    echo "VERSION=${versionBase} committed to coin/coin-cli"
                }
            }
        }
    }

    post {
        success {
            script {
                if (params.PUBLISH && !params.SNAPSHOT) {
                    echo 'Release опубликован. Обновите coinCli.version в GP profile.yaml (platform bundle).'
                }
                if (params.PUBLISH) {
                    echo 'После job: make coin-cli — подтянет VERSION из Gitea в monorepo.'
                }
            }
        }
    }
}
