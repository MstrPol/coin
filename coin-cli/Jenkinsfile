// Platform CI: coin CLI → Nexus Maven (zip, classifier linux-<arch>).
// Репозитории maven-releases / maven-snapshots — из коробки Nexus, bootstrap не трогаем.
pipeline {
    agent any

    environment {
        COIN_CLI_VERSION = '0.0.0-SNAPSHOT'
        MAVEN_GROUP = 'coin.platform'
        MAVEN_ARTIFACT = 'coin-cli'
        NEXUS_BASE = 'http://nexus:8081/repository'
        GO_IMAGE = 'golang:1.22'
        MVN_IMAGE = 'maven:3.9-eclipse-temurin-17'
    }

    stages {
        stage('Test') {
            steps {
                sh '''
                    docker run --rm -v "${WORKSPACE}:/w" -w /w ${GO_IMAGE} go test ./...
                '''
            }
        }
        stage('Build') {
            steps {
                script {
                    env.GOARCH = sh(script: '''case "$(uname -m)" in
                        arm64|aarch64) echo arm64 ;;
                        x86_64|amd64) echo amd64 ;;
                        *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                    esac''', returnStdout: true).trim()
                }
                sh '''
                    docker run --rm \
                      -e GOOS=linux -e GOARCH=${GOARCH} -e CGO_ENABLED=0 \
                      -v "${WORKSPACE}:/w" -w /w ${GO_IMAGE} \
                      go build -ldflags "-X coin.local/coin-cli/cmd.Version=${COIN_CLI_VERSION}" -o coin .
                '''
            }
        }
        stage('Publish Maven') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-admin',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASSWORD',
                )]) {
                    sh '''
                        set -euo pipefail
                        zip -j "coin-cli-linux-${GOARCH}.zip" coin

                        if [[ "${COIN_CLI_VERSION}" == *SNAPSHOT ]]; then
                          MAVEN_REPO="maven-snapshots"
                        else
                          MAVEN_REPO="maven-releases"
                        fi
                        MAVEN_URL="${NEXUS_BASE}/${MAVEN_REPO}/"

                        cat > settings.xml <<EOF
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <servers>
    <server>
      <id>nexus-maven</id>
      <username>${NEXUS_USER}</username>
      <password>${NEXUS_PASSWORD}</password>
    </server>
  </servers>
</settings>
EOF

                        docker run --rm \
                          -v "${WORKSPACE}:/w" -w /w \
                          ${MVN_IMAGE} \
                          mvn -s /w/settings.xml deploy:deploy-file \
                            -DgroupId="${MAVEN_GROUP}" \
                            -DartifactId="${MAVEN_ARTIFACT}" \
                            -Dversion="${COIN_CLI_VERSION}" \
                            -Dpackaging=zip \
                            -Dclassifier="linux-${GOARCH}" \
                            -Dfile="coin-cli-linux-${GOARCH}.zip" \
                            -DrepositoryId=nexus-maven \
                            -Durl="${MAVEN_URL}"

                        GAV_PATH="${MAVEN_GROUP//./\/}/${MAVEN_ARTIFACT}/${COIN_CLI_VERSION}"
                        echo "published ${MAVEN_URL}${GAV_PATH}/${MAVEN_ARTIFACT}-${COIN_CLI_VERSION}-linux-${GOARCH}.zip"
                    '''
                }
            }
        }
    }
}
