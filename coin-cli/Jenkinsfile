// Platform CI: coin CLI → Nexus Maven (zip, classifier linux-<arch>).
// Test/Build — K8s dynamic agent (ci-go из coin-platform/agents/catalog.yaml).
@Library('coin-lib') _

def goStackImage(catalog) {
    def entry = catalog.stacks?.go?.'1.22'
    if (!entry?.image) {
        error('agents/catalog.yaml: нет stacks.go.1.22')
    }
    def registry = catalog.registry?.default ?: 'nexus:8082/coin-docker'
    def tag = entry.tag ?: "1.22-r${entry.rev ?: 0}"
    return "${registry}/${entry.image}:${tag}"
}

pipeline {
    agent none

    environment {
        COIN_CLI_VERSION = '0.0.0-SNAPSHOT'
        MAVEN_GROUP = 'coin.platform'
        MAVEN_ARTIFACT = 'coin-cli'
        NEXUS_BASE = 'http://nexus:8081/repository'
    }

    stages {
        stage('Test & Build') {
            steps {
                script {
                    def stackImage
                    def jnlpImage
                    node('built-in') {
                        checkout scm
                        coinPlatformCheckout([:])
                        def catalog = readYaml file: "${env.COIN_PLATFORM_DIR}/agents/catalog.yaml"
                        def platform = readYaml file: "${env.COIN_PLATFORM_DIR}/platform.yaml"
                        stackImage = goStackImage(catalog)
                        jnlpImage = platform.jenkins?.jnlp?.image
                        if (!jnlpImage) {
                            error('platform.yaml: jenkins.jnlp.image не задан')
                        }
                        echo "coin-cli agent: ${stackImage}"
                    }

                    def podLabel = "coin-cli-${env.BUILD_NUMBER}"
                    def podYaml = coinPodTemplate(jnlpImage, stackImage)
                    podTemplate(yaml: podYaml, cloud: 'kubernetes', label: podLabel) {
                        node(podLabel) {
                            checkout scm
                            coinPlatformCheckout([:])
                            container('stack') {
                                sh 'go test ./...'
                                sh '''
                                    set -eu
                                    case "$(uname -m)" in
                                        arm64|aarch64) GOARCH=arm64 ;;
                                        x86_64|amd64) GOARCH=amd64 ;;
                                        *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                                    esac
                                    GOOS=linux CGO_ENABLED=0 GOARCH="${GOARCH}" go build \
                                      -buildvcs=false \
                                      -ldflags "-X coin.local/coin-cli/cmd.Version=${COIN_CLI_VERSION}" \
                                      -o coin .
                                    echo "${GOARCH}" > .goarch
                                '''
                                stash includes: 'coin,.goarch', name: 'coin-binary'
                            }
                        }
                    }
                }
            }
        }

        stage('Publish Maven') {
            agent { label 'built-in' }
            steps {
                unstash 'coin-binary'
                script {
                    env.GOARCH = readFile('.goarch').trim()
                }
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-admin',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASSWORD',
                )]) {
                    sh '''
                        set -eu
                        ZIP="coin-cli-linux-${GOARCH}.zip"
                        zip -j "${ZIP}" coin

                        case "${COIN_CLI_VERSION}" in
                          *SNAPSHOT*) MAVEN_REPO=maven-snapshots ;;
                          *) MAVEN_REPO=maven-releases ;;
                        esac

                        GAV_PATH="$(echo "${MAVEN_GROUP}" | tr "." "/")/${MAVEN_ARTIFACT}/${COIN_CLI_VERSION}"
                        REMOTE="${NEXUS_BASE}/${MAVEN_REPO}/${GAV_PATH}/${MAVEN_ARTIFACT}-${COIN_CLI_VERSION}-linux-${GOARCH}.zip"
                        curl -f -S -u "${NEXUS_USER}:${NEXUS_PASSWORD}" \
                          -X PUT --upload-file "${ZIP}" "${REMOTE}"

                        echo "published ${REMOTE}"
                    '''
                }
            }
        }
    }
}
