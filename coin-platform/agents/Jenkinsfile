// Platform CI: сборка CI agent image → registry → bump catalog (rev, tag, digest) → git push.
// Параметры STACK / RUNTIME / BUILD_ALL — Active Choices в Job DSL (docker/jenkins/jobs/coin-agents.groovy).
pipeline {
    agent any

    environment {
        CATALOG = 'coin-jenkins-agents/catalog.yaml'
        GIT_AUTHOR_EMAIL = 'jenkins@coin.local'
        GIT_AUTHOR_NAME = 'Jenkins'
    }

    stages {
        stage('Build agents') {
            steps {
                script {
                    def catalog = readYaml file: env.CATALOG
                    def targets = []

                    if (params.BUILD_ALL) {
                        catalog.stacks.each { stack, runtimes ->
                            runtimes.each { runtime, _ ->
                                targets << [stack: stack, runtime: runtime.toString()]
                            }
                        }
                    } else {
                        targets << [stack: params.STACK, runtime: params.RUNTIME.trim()]
                    }

                    for (def t : targets) {
                        buildOneAgent(catalog, t.stack, t.runtime)
                    }
                }
            }
        }
    }
}

def buildOneAgent(catalog, stack, runtime) {
    def entry = catalog.stacks?."${stack}"?."${runtime}"
    if (!entry) {
        error("catalog: нет stacks.${stack}.${runtime}")
    }

    def registry = catalog.registry?.default ?: 'registry:5000/coin'
    def registryHost = registry.split('/')[0]
    def credId = catalog.registry?.credentialsId ?: 'nexus-docker'

    def nextRev = (entry.rev ?: 0) + 1
    def tag = "${runtime}-r${nextRev}"
    def imageRepo = entry.image
    def dockerfile = entry.dockerfile
    def ref = "${registry}/${imageRepo}:${tag}"

    def goarch = sh(
        script: '''case "$(uname -m)" in
            arm64|aarch64) echo arm64 ;;
            x86_64|amd64) echo amd64 ;;
            *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
        esac''',
        returnStdout: true,
    ).trim()

    echo "==> agent ${stack}/${runtime} → ${ref}"

    withCredentials([usernamePassword(
        credentialsId: credId,
        usernameVariable: 'REG_USER',
        passwordVariable: 'REG_PASS',
    )]) {
        sh """
            set -euo pipefail
            echo "\${REG_PASS}" | docker login '${registryHost}' -u "\${REG_USER}" --password-stdin
            docker build --platform 'linux/${goarch}' -f '${dockerfile}' -t '${ref}' .
            docker push '${ref}'
        """
    }

    def digest = sh(
        script: "docker inspect --format='{{.Id}}' '${ref}'",
        returnStdout: true,
    ).trim()

    echo "digest=${digest}"

    entry.rev = nextRev
    entry.tag = tag
    entry.digest = digest
    catalog.stacks."${stack}"."${runtime}" = entry

    writeYaml file: env.CATALOG, data: catalog, overwrite: true

    withCredentials([usernamePassword(
        credentialsId: 'gitea-git',
        usernameVariable: 'GIT_USER',
        passwordVariable: 'GIT_PASS',
    )]) {
        sh """
            set -euo pipefail
            git add '${env.CATALOG}'
            git diff --staged --quiet && exit 0
            git -c user.email='${env.GIT_AUTHOR_EMAIL}' -c user.name='${env.GIT_AUTHOR_NAME}' \\
              commit -m 'chore(agents): ${stack}/${runtime} ${tag} [skip ci]'
            git push 'http://\${GIT_USER}:\${GIT_PASS}@gitea:3000/coin/coin.git' HEAD:main
        """
    }
}
