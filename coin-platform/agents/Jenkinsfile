// Platform CI: сборка CI agent images → Nexus Docker → bump agents/catalog.yaml → git push.
pipeline {
    agent any

    parameters {
        string(name: 'STACK', defaultValue: 'go', description: 'Stack из agents/catalog.yaml')
        string(name: 'RUNTIME', defaultValue: '1.22', description: 'Runtime version из agents/catalog.yaml')
    }

    environment {
        AGENTS_DIR = 'agents'
        CATALOG = 'agents/catalog.yaml'
        GIT_AUTHOR_EMAIL = 'jenkins@coin.local'
        GIT_AUTHOR_NAME = 'Jenkins'
        GITEA_REPO = 'http://gitea:3000/coin/coin-platform.git'
    }

    stages {
        stage('Build agents') {
            steps {
                dir(env.AGENTS_DIR) {
                    script {
                        def catalog = readYaml file: 'catalog.yaml'
                        buildOneAgent(catalog, params.STACK.trim(), params.RUNTIME.trim())
                    }
                }
            }
        }
    }
}

def buildOneAgent(catalog, stack, runtime) {
    def entry = catalog.stacks?."${stack}"?."${runtime}"
    if (!entry) {
        error("catalog: нет stacks.${stack}.${runtime}")
    }

    def registry = env.COIN_REGISTRY_PREFIX ?: catalog.registry?.default ?: 'nexus:8082/coin-docker'
    def registryHost = registry.split('/')[0]
    def credId = catalog.registry?.credentialsId ?: 'nexus-docker'

    def nextRev = (entry.rev ?: 0) + 1
    def tag = "${runtime}-r${nextRev}"
    def imageRepo = entry.image
    def dockerfile = entry.dockerfile
    def ref = "${registry}/${imageRepo}:${tag}"

    def goarch = sh(
        script: '''case "$(uname -m)" in
            arm64|aarch64) echo arm64 ;;
            x86_64|amd64) echo amd64 ;;
            *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
        esac''',
        returnStdout: true,
    ).trim()

    echo "==> agent ${stack}/${runtime} → ${ref}"

    withCredentials([usernamePassword(
        credentialsId: credId,
        usernameVariable: 'REG_USER',
        passwordVariable: 'REG_PASS',
    )]) {
        sh """
            set -euo pipefail
            export DOCKER_CONFIG="\${WORKSPACE}/.docker"
            mkdir -p "\${DOCKER_CONFIG}"
            echo "\${REG_PASS}" | docker login '${registryHost}' -u "\${REG_USER}" --password-stdin
            docker build --platform 'linux/${goarch}' -f '${dockerfile}' -t '${ref}' .
            docker push '${ref}'
        """
    }

    def digest = sh(
        script: "docker inspect --format='{{.Id}}' '${ref}'",
        returnStdout: true,
    ).trim()

    echo "digest=${digest}"

    entry.rev = nextRev
    entry.tag = tag
    entry.digest = digest
    catalog.stacks."${stack}"."${runtime}" = entry

    pushCatalogUpdate(catalog, stack, runtime, tag)
}

def pushCatalogUpdate(catalog, stack, runtime, tag) {
    withCredentials([usernamePassword(
        credentialsId: 'gitea-git',
        usernameVariable: 'GIT_USER',
        passwordVariable: 'GIT_PASS',
    )]) {
        sh(script: """
            set -euo pipefail
            export HOME=/var/jenkins_home
            cd "\${WORKSPACE}"
            git fetch origin main
            git checkout -B main origin/main
        """)
    }

    writeYaml file: "${env.WORKSPACE}/agents/catalog.yaml", data: catalog, overwrite: true

    withCredentials([usernamePassword(
        credentialsId: 'gitea-git',
        usernameVariable: 'GIT_USER',
        passwordVariable: 'GIT_PASS',
    )]) {
        sh(script: """
            set -euo pipefail
            export HOME=/var/jenkins_home
            cd "\${WORKSPACE}"
            git add agents/catalog.yaml
            git diff --staged --quiet && exit 0
            git -c user.email='${env.GIT_AUTHOR_EMAIL}' -c user.name='${env.GIT_AUTHOR_NAME}' \\
              commit -m 'chore(agents): ${stack}/${runtime} ${tag} [skip ci]'
            git push "http://\${GIT_USER}:\${GIT_PASS}@gitea:3000/coin/coin-platform.git" main
        """)
    }
}
