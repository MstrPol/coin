# syntax=docker/dockerfile:1.8
# Universal Coin Jenkins agent: inbound-agent + coin-executor + BuildKit + pack/podman.
ARG REGISTRY=""
ARG JENKINS_INBOUND_AGENT_TAG=3327.v868139a_d00e0-8
ARG BUILDKIT_VERSION=v0.17.3
ARG PACK_VERSION=0.36.2

FROM ${REGISTRY}golang:1.22-bookworm AS executor-builder

ARG GOPROXY="https://proxy.golang.org,direct"
ARG GOPRIVATE=""
ARG GOINSECURE="*"
ARG GIT_SSL_NO_VERIFY=true

ENV GOINSECURE=${GOINSECURE} \
    GIT_SSL_NO_VERIFY=${GIT_SSL_NO_VERIFY}

WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=secret,id=go_auth \
    if [ -f /run/secrets/go_auth ]; then cat /run/secrets/go_auth > ~/.netrc; fi && \
    go mod download

COPY . .
ARG VERSION=0.1.0-dev
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    VERSION="$(tr -d '[:space:]' < VERSION 2>/dev/null || echo "${VERSION}")" && \
    CGO_ENABLED=0 GOOS=linux go build -buildvcs=false \
    -ldflags "-X main.Version=${VERSION}" \
    -o /coin-executor ./cmd/coin-executor

FROM ${REGISTRY}moby/buildkit:${BUILDKIT_VERSION}-rootless AS buildkit-rootless

FROM ${REGISTRY}jenkins/inbound-agent:${JENKINS_INBOUND_AGENT_TAG}

USER root
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       curl git jq ca-certificates podman fuse-overlayfs \
       slirp4netns iptables \
  && rm -rf /var/lib/apt/lists/*

ARG PACK_VERSION
ARG TARGETARCH
COPY pack /usr/local/bin/pack
RUN chmod +x /usr/local/bin/pack

COPY --from=buildkit-rootless /usr/bin/buildkitd /usr/local/bin/buildkitd
COPY --from=buildkit-rootless /usr/bin/buildctl /usr/local/bin/buildctl
COPY --from=buildkit-rootless /usr/bin/buildkit-runc /usr/local/bin/runc
COPY --from=buildkit-rootless /usr/bin/rootlesskit /usr/local/bin/rootlesskit
RUN ln -sf /usr/local/bin/runc /usr/bin/runc
COPY buildkitd.toml /etc/buildkit/buildkitd.toml
COPY podman-containers.conf /etc/containers/containers.conf
COPY podman-storage.conf /etc/containers/storage.conf
COPY podman-registries.conf /etc/containers/registries.conf
COPY --from=executor-builder /coin-executor /usr/local/bin/coin-executor
RUN chmod +x /usr/local/bin/coin-executor /usr/local/bin/buildkitd /usr/local/bin/buildctl /usr/local/bin/runc /usr/local/bin/rootlesskit

# Buildpack builder baked as tar (loaded into podman at bootstrap; avoids registry pull in pod).
COPY paketo-builder.tar /usr/share/coin/paketo-builder.tar

# coin-agent: Switch back to jenkins user for rootless operations
RUN mkdir -p /home/jenkins/.local/share/containers/storage /run/user/1000 \
  && chown -R 1000:1000 /home/jenkins/.local /run/user/1000

ENV XDG_RUNTIME_DIR=/run/user/1000
USER 1000
