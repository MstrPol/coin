// Platform CI: bump semver → test → docker build coin-agent (Dockerfile.agent) → push → register draft.

pipeline {
    agent any

    parameters {
        choice(
            name: 'BUMP',
            choices: ['patch', 'minor', 'major'],
            description: 'Semver bump от VERSION в репозитории',
        )
        choice(
            name: 'GOARCH',
            choices: ['arm64', 'amd64'],
            description: 'Target architecture for coin-agent image (binary built inside Dockerfile.agent)',
        )
        string(name: 'GOPROXY', defaultValue: 'https://proxy.golang.org,direct', description: 'Go proxy для builder stage в Dockerfile.agent')
    }

    environment {
        COIN_API_URL = 'http://coin-api:8090'
        NEXUS_DOCKER_PORT = '8082'
        NEXUS_DOCKER_REPO = 'coin-docker'
    }

    stages {
        stage('Resolve version') {
            steps {
                script {
                    def next = bumpVersionFromFile(params.BUMP)
                    env.COIN_EXECUTOR_VERSION = next
                    echo "==> coin-agent image version → ${next}"
                }
            }
        }

        stage('Preflight runtime') {
            steps {
                sh '''
                    set -eu
                    command -v docker >/dev/null 2>&1 || { echo "docker CLI not found in Jenkins node" >&2; exit 1; }
                    docker version >/dev/null 2>&1 || { echo "docker daemon is not reachable from Jenkins node" >&2; exit 1; }
                    code="$(curl -sS -o /dev/null -w '%{http_code}' "http://nexus:${NEXUS_DOCKER_PORT}/v2/" || true)"
                    case "${code}" in
                        200|401) : ;;
                        *) echo "nexus docker registry endpoint is not reachable: nexus:${NEXUS_DOCKER_PORT} (HTTP ${code})" >&2; exit 1 ;;
                    esac
                '''
            }
        }

        stage('Test') {
            steps {
                script {
                    withEnv([
                        "GOPROXY=${params.GOPROXY}",
                        "GOINSECURE=*",
                        "GIT_SSL_NO_VERIFY=true"
                    ]) {
                        sh '''
                            set -eu
                            GO_VERSION=1.24.0
                            GO_ROOT="${WORKSPACE}/.go"
                            case "$(uname -m)" in
                                arm64|aarch64) GOARCH_DL=arm64 ;;
                                x86_64|amd64) GOARCH_DL=amd64 ;;
                                *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                            esac
                            if [ ! -x "${GO_ROOT}/bin/go" ]; then
                                mkdir -p "${GO_ROOT}"
                                curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GOARCH_DL}.tar.gz" \
                                    | tar -C "${GO_ROOT}" --strip-components=1 -xz
                            fi
                            export PATH="${GO_ROOT}/bin:${PATH}"
                            export GOROOT="${GO_ROOT}"
                            export GOCACHE="${WORKSPACE}/.cache/go-build"
                            export GOMODCACHE="${WORKSPACE}/.cache/go-mod"
                            mkdir -p "${GOCACHE}" "${GOMODCACHE}"

                            echo "Running tests..."
                            go test ./...
                        '''
                    }
                }
            }
        }

        stage('Publish agent image') {
            steps {
                withEnv([
                    "GOARCH=${params.GOARCH}",
                    "GOPROXY=${params.GOPROXY}",
                ]) {
                    withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-docker',
                        usernameVariable: 'NEXUS_DOCKER_USER',
                        passwordVariable: 'NEXUS_DOCKER_PASSWORD',
                    ),
                    string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY'),
                ]) {
                    sh '''
                        set -eu
                        chmod +x scripts/publish-agent.sh
                        DOCKER_CONFIG="${WORKSPACE}/.docker" \
                        COIN_API_URL="${COIN_API_URL}" \
                        NEXUS_DOCKER_PORT="${NEXUS_DOCKER_PORT}" \
                        NEXUS_DOCKER_REPO="${NEXUS_DOCKER_REPO}" \
                        NEXUS_DOCKER_USER="${NEXUS_DOCKER_USER}" \
                        NEXUS_DOCKER_PASSWORD="${NEXUS_DOCKER_PASSWORD}" \
                        COIN_API_KEY="${COIN_API_KEY}" \
                        GOPROXY="${GOPROXY}" \
                        GOARCH="${GOARCH}" \
                        ./scripts/publish-agent.sh "${COIN_EXECUTOR_VERSION}" "${GOARCH}"
                    '''
                }
                }
            }
        }
    }
}

def bumpVersionFromFile(String bump) {
    def current = readFile('VERSION').trim()
    def next = sh(
        script: """
            python3 - <<'PY'
import sys
parts = [int(x) for x in "${current}".split(".")]
while len(parts) < 3:
    parts.append(0)
bump = "${bump}"
if bump == "major":
    parts[0] += 1
    parts[1] = 0
    parts[2] = 0
elif bump == "minor":
    parts[1] += 1
    parts[2] = 0
else:
    parts[2] += 1
print(".".join(str(p) for p in parts))
PY
        """,
        returnStdout: true,
    ).trim()
    writeFile file: 'VERSION', text: next + '\n'
    return next
}
