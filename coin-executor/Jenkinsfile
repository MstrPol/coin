// Platform CI: bump semver → build → Nexus maven2 → register in coin-api.

def coinPodYaml(String jnlpImage, String stackImage) {
    return """\
apiVersion: v1
kind: Pod
spec:
  containers:
    - name: jnlp
      image: ${jnlpImage}
    - name: stack
      image: ${stackImage}
      command: ["sleep"]
      args: ["infinity"]
      tty: true
      securityContext:
        runAsUser: 0
      env:
        - name: COIN_REGISTRY_PREFIX
          value: "localhost:8082/coin-docker"
      volumeMounts:
        - name: docker-sock
          mountPath: /var/run/docker.sock
  volumes:
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
        type: Socket
""".stripIndent()
}

def coinApiUrl() {
    return env.COIN_API_URL ?: 'http://coin-api:8090'
}

@NonCPS
def parseLatestComponentVersion(String json, String runtimePrefix = '') {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    def items = parsed.items ?: []
    for (item in items) {
        def version = item.version?.toString() ?: ''
        if (!version) {
            continue
        }
        if (!runtimePrefix || version.startsWith("${runtimePrefix}-")) {
            return version
        }
    }
    return ''
}

@NonCPS
def parseComponentMetadataImage(String json) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    def image = parsed.metadata?.image
    return image ? image.toString() : ''
}

def componentImage(typ, name, String runtimePrefix = '') {
    def apiUrl = coinApiUrl()
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        def listStatus = sh(
            script: """
                set +e
                code=\$(curl -s -o versions.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${apiUrl}/v1/admin/components/${typ}/${name}/versions')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (listStatus == '404') {
            def hint = (typ == 'agent' && name == 'jnlp')
                ? ' (выполните: cd docker && make register-jnlp)'
                : ' (соберите через agents-build)'
            error("coin-api: компонент ${typ}/${name} не зарегистрирован${hint}")
        }
        if (listStatus != '200') {
            error("coin-api: ${typ}/${name}/versions HTTP ${listStatus}")
        }
        def latest = parseLatestComponentVersion(readFile('versions.json'), runtimePrefix)
        if (!latest) {
            def hint = runtimePrefix
                ? " (соберите agents/${name}/${runtimePrefix}.Dockerfile через agents-build)"
                : ''
            error("coin-api: нет опубликованных версий ${typ}/${name}${hint}")
        }
        def detailStatus = sh(
            script: """
                set +e
                code=\$(curl -s -o version-detail.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${apiUrl}/v1/admin/components/${typ}/${name}/versions/${latest}')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (detailStatus != '200') {
            error("coin-api: ${typ}/${name}/versions/${latest} HTTP ${detailStatus}")
        }
        def image = parseComponentMetadataImage(readFile('version-detail.json'))
        if (!image) {
            error("coin-api: metadata.image не задан для ${typ}/${name}@${latest}")
        }
        return image
    }
}

@NonCPS
def parseNextExecutorVersionResponse(String json, String bump) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    return [
        bump: bump,
        currentVersion: (parsed.currentVersion ?: '').toString(),
        nextVersion: parsed.nextVersion.toString(),
        isFirst: parsed.isFirst == true,
    ]
}

def nextExecutorVersion(bump) {
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        def status = sh(
            script: """
                set +e
                code=\$(curl -s -o next-ver.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${coinApiUrl()}/v1/admin/components/executor/coin-executor/next-version?bump=${bump}')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (status == '200') {
            return parseNextExecutorVersionResponse(readFile('next-ver.json'), bump)
        }
        error("executor next-version HTTP ${status}")
    }
}

pipeline {
    agent none

    parameters {
        choice(
            name: 'BUMP',
            choices: ['patch', 'minor', 'major'],
            description: 'Semver bump от latest published в coin-api',
        )
    }

    environment {
        COIN_API_URL = 'http://coin-api:8090'
        NEXUS_URL = 'http://nexus:8081'
        NEXUS_MAVEN_RELEASES = 'maven-releases'
        NEXUS_MAVEN_SNAPSHOTS = 'maven-snapshots'
    }

    stages {
        stage('Resolve version') {
            agent { label 'built-in' }
            steps {
                script {
                    def alloc = nextExecutorVersion(params.BUMP)
                    env.COIN_EXECUTOR_VERSION = alloc.nextVersion
                    if (alloc.isFirst) {
                        echo "==> executor/coin-executor: первая регистрация → ${alloc.nextVersion}"
                    } else {
                        echo "==> executor/coin-executor: ${alloc.currentVersion} + ${params.BUMP} → ${alloc.nextVersion}"
                    }
                }
            }
        }

        stage('Test & Build') {
            steps {
                script {
                    def stackImage
                    def jnlpImage
                    node('built-in') {
                        stackImage = componentImage('agent', 'go', '1.24')
                        jnlpImage = componentImage('agent', 'jnlp')
                    }

                    def podLabel = "coin-executor-${env.BUILD_NUMBER}"
                    def podYaml = coinPodYaml(jnlpImage, stackImage)
                    podTemplate(yaml: podYaml, cloud: 'kubernetes', label: podLabel) {
                        node(podLabel) {
                            checkout scm
                            container('stack') {
                                echo "coin-executor version: ${env.COIN_EXECUTOR_VERSION}"
                                sh 'go test ./...'
                                sh '''
                                    set -eu
                                    case "$(uname -m)" in
                                        arm64|aarch64) GOARCH=arm64 ;;
                                        x86_64|amd64) GOARCH=amd64 ;;
                                        *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                                    esac
                                    GOOS=linux CGO_ENABLED=0 GOARCH="${GOARCH}" go build \
                                      -buildvcs=false \
                                      -ldflags "-X main.Version=${COIN_EXECUTOR_VERSION}" \
                                      -o coin-executor ./cmd/coin-executor
                                    echo "${GOARCH}" > .goarch
                                '''
                                stash includes: 'coin-executor,.goarch', name: 'executor-binary'
                            }
                        }
                    }
                }
            }
        }

        stage('Publish') {
            agent { label 'built-in' }
            steps {
                unstash 'executor-binary'
                script {
                    env.GOARCH = readFile('.goarch').trim()
                }
                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-admin',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASSWORD',
                    ),
                    string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY'),
                ]) {
                    sh './scripts/publish-executor.sh "${COIN_EXECUTOR_VERSION}" "${GOARCH}"'
                }
            }
        }
    }
}
