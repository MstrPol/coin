// Platform CI: bump semver → test/build binary → Nexus maven2 → register in coin-api.

pipeline {
    agent any

    tools {
        go 'golang-1.22'
    }

    parameters {
        choice(
            name: 'BUMP',
            choices: ['patch', 'minor', 'major'],
            description: 'Semver bump от latest published в coin-api',
        )
        string(name: 'GOPROXY', defaultValue: 'https://proxy.golang.org,direct', description: 'URL to Go Proxy/Nexus')
        string(name: 'GO_AUTH_CRED_ID', defaultValue: 'go-auth-token', description: 'Credentials ID for private Go modules (.netrc format)')
    }

    environment {
        COIN_API_URL = 'http://coin-api:8090'
        NEXUS_URL = 'http://nexus:8081'
        NEXUS_MAVEN_RELEASES = 'maven-releases'
        NEXUS_MAVEN_SNAPSHOTS = 'maven-snapshots'
    }

    stages {
        stage('Resolve version') {
            steps {
                script {
                    def alloc = nextExecutorVersion(params.BUMP)
                    env.COIN_EXECUTOR_VERSION = alloc.nextVersion
                    if (alloc.isFirst) {
                        echo "==> executor/coin-executor: первая регистрация → ${alloc.nextVersion}"
                    } else {
                        echo "==> executor/coin-executor: ${alloc.currentVersion} + ${params.BUMP} → ${alloc.nextVersion}"
                    }
                }
            }
        }

        stage('Test & Build') {
            steps {
                script {
                    // Используем настройки авторизации и отключения SSL
                    withEnv([
                        "GOPROXY=${params.GOPROXY}", 
                        "GOINSECURE=*", 
                        "GIT_SSL_NO_VERIFY=true"
                    ]) {
                        withCredentials([string(credentialsId: params.GO_AUTH_CRED_ID, variable: 'GO_AUTH')]) {
                            sh '''
                                set -eu
                                if [ -n "$GO_AUTH" ]; then
                                    echo "$GO_AUTH" > ~/.netrc
                                fi
                                
                                echo "Running tests..."
                                go test ./...
                                
                                case "$(uname -m)" in
                                    arm64|aarch64) GOARCH=arm64 ;;
                                    x86_64|amd64) GOARCH=amd64 ;;
                                    *) echo "unsupported: $(uname -m)" >&2; exit 1 ;;
                                esac
                                
                                echo "Building for ${GOARCH}..."
                                GOOS=linux CGO_ENABLED=0 GOARCH="${GOARCH}" go build -buildvcs=false \
                                    -ldflags "-X main.Version=${COIN_EXECUTOR_VERSION}" \
                                    -o coin-executor ./cmd/coin-executor
                                    
                                echo "${GOARCH}" > .goarch
                            '''
                        }
                    }
                }
                stash includes: 'coin-executor,.goarch', name: 'executor-binary'
            }
        }

        stage('Publish') {
            steps {
                unstash 'executor-binary'
                script {
                    env.GOARCH = readFile('.goarch').trim()
                }
                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-admin',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASSWORD',
                    ),
                    string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY'),
                ]) {
                    publishExecutor(env.COIN_EXECUTOR_VERSION, env.GOARCH)
                }
            }
        }
    }
}

// ---------------------------------------------------------
// Вспомогательные функции (объявлены в конце файла)
// ---------------------------------------------------------

def coinApiUrl() {
    return env.COIN_API_URL ?: 'http://coin-api:8090'
}

@NonCPS
def parseNextExecutorVersionResponse(String json, String bump) {
    def parsed = new groovy.json.JsonSlurper().parseText(json)
    return [
        bump: bump,
        currentVersion: (parsed.currentVersion ?: '').toString(),
        nextVersion: parsed.nextVersion.toString(),
        isFirst: parsed.isFirst == true,
    ]
}

def nextExecutorVersion(bump) {
    withCredentials([string(credentialsId: 'coin-publisher-api-key', variable: 'COIN_API_KEY')]) {
        def status = sh(
            script: """
                set +e
                code=\$(curl -s -o next-ver.json -w '%{http_code}' \\
                  -H "X-API-Key: \${COIN_API_KEY}" \\
                  '${coinApiUrl()}/v1/admin/components/executor/coin-executor/next-version?bump=${bump}')
                echo "\${code}"
            """,
            returnStdout: true,
        ).trim()
        if (status == '200') {
            return parseNextExecutorVersionResponse(readFile('next-ver.json'), bump)
        }
        error("executor next-version HTTP ${status}")
    }
}

def publishExecutor(String version, String goarch) {
    def binaryPath = 'coin-executor'
    def repo = (version.contains('SNAPSHOT') || version.contains('-dev')) ? env.NEXUS_MAVEN_SNAPSHOTS : env.NEXUS_MAVEN_RELEASES
    def nexusTarget = "${env.NEXUS_URL}/repository/${repo}/coin/executor/coin-executor/${version}/coin-executor-${version}-${goarch}"
    def apiUrl = coinApiUrl()

    // 1. Считаем SHA256
    def shaOut = sh(script: "sha256sum ${binaryPath} | awk '{print \$1}'", returnStdout: true).trim()
    def sha256 = "sha256:${shaOut}"

    // 2. Публикуем в Nexus
    def nexusAuth = "${env.NEXUS_USER}:${env.NEXUS_PASSWORD}"
    def checkCode = sh(script: "curl -s -o /dev/null -w '%{http_code}' -u '${nexusAuth}' -I '${nexusTarget}' || true", returnStdout: true).trim()
    
    if (checkCode == '200') {
        echo "==> already in Nexus, skip upload: ${nexusTarget}"
    } else {
        echo "==> upload ${binaryPath} -> ${nexusTarget}"
        def uploadCode = sh(
            script: "curl -sS -u '${nexusAuth}' -o upload.out -w '%{http_code}' -H 'Content-Type: application/octet-stream' --upload-file '${binaryPath}' '${nexusTarget}'",
            returnStdout: true
        ).trim()
        
        if (uploadCode != '201' && uploadCode != '200' && uploadCode != '204') {
            def body = readFile('upload.out').trim()
            if (uploadCode == '400' && body.contains('already exists')) {
                echo "==> already in Nexus (immutable repo), continue: ${nexusTarget}"
            } else {
                error("nexus upload failed HTTP ${uploadCode}: ${body}")
            }
        }
    }

    // 3. Регистрируем в coin-api
    echo "==> register executor/coin-executor@${version}"
    def payload = """
    {
        "version": "${version}",
        "metadata": {
            "url": "${nexusTarget}",
            "goarch": "${goarch}",
            "sha256": "${sha256}"
        },
        "actor": "jenkins-executor"
    }
    """
    writeFile file: 'payload.json', text: payload
    
    def regCode = sh(
        script: """
            curl -sS -o reg.out -w '%{http_code}' -X POST \\
            '${apiUrl}/v1/admin/components/executor/coin-executor/versions' \\
            -H "Content-Type: application/json" \\
            -H "X-API-Key: ${env.COIN_API_KEY}" \\
            -d @payload.json
        """,
        returnStdout: true
    ).trim()
    
    if (regCode != '201' && regCode != '409') {
        error("coin-api register failed HTTP ${regCode}: " + readFile('reg.out'))
    }
    if (regCode == '409') {
        echo "==> version already registered in coin-api"
    }
    echo "==> done executor/coin-executor@${version} (${goarch})"
}
