# Скопируйте: cp .env.example .env  (make bootstrap создаёт .env автоматически)

COMPOSE_PROJECT_NAME=coin

# Образы сервисов: linux/arm64 (Apple Silicon) | linux/amd64 (Intel)
DOCKER_PLATFORM=linux/arm64

# Jenkins
JENKINS_HTTP_PORT=8080
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin

# Gitea — UI, git push (make coin-* / make samples)
GITEA_HTTP_PORT=3000
GITEA_USER=coin
GITEA_PASSWORD=coin
GITEA_EMAIL=coin@local

# Nexus — UI + Docker connector (prepare-nexus.sh)
NEXUS_HTTP_PORT=8081
NEXUS_DOCKER_PORT=8082
NEXUS_DOCKER_REPO=coin-docker
NEXUS_DOCKER_USER=coin
NEXUS_DOCKER_PASSWORD=coin1234
NEXUS_ADMIN_PASSWORD=coin12345
NEXUS_IMAGE_TAG=3.91.1-alpine

# k3s — API; Dashboard UI: make dashboard (NodePort 30443 → host)
K3S_API_PORT=6443
K3S_DASHBOARD_PORT=8443
