# Скопируйте в docker/.env и при необходимости измените.
COMPOSE_PROJECT_NAME=coin

REGISTRY_HOST=registry
# 5000 на macOS часто занят AirPlay Receiver — используйте 5050
REGISTRY_PORT=5050
REGISTRY_PREFIX=${REGISTRY_HOST}:${REGISTRY_PORT}

# Apple Silicon: linux/arm64. Intel/Linux CI: linux/amd64
DOCKER_PLATFORM=linux/arm64

JENKINS_HTTP_PORT=8080
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin

GITEA_HTTP_PORT=3000
GITEA_USER=coin
GITEA_PASSWORD=coin
GITEA_EMAIL=coin@local

NEXUS_HTTP_PORT=8081
NEXUS_ADMIN_PASSWORD=coin12345
# multi-arch (arm64 + amd64); не используйте 3.76.x на Apple Silicon
NEXUS_IMAGE_TAG=3.91.1-alpine

K3S_API_PORT=6443
K3S_DASHBOARD_PORT=8443

# Образы coin agents после push в локальный registry
COIN_AGENT_REGISTRY=${REGISTRY_PREFIX}/coin
