{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/config.v1.json",
  "title": "Coin CI config",
  "type": "object",
  "required": ["version", "project", "pipeline"],
  "additionalProperties": false,
  "properties": {
    "coin": {
      "type": "object",
      "properties": {
        "template": { "type": "string" },
        "templateVersion": { "type": "string" },
        "mode": { "type": "string", "enum": ["standard", "strict"] },
        "versioning": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["corporate"] },
            "tagPrefix": { "type": "string" }
          }
        }
      }
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "required": ["name", "stack"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "stack": {
          "type": "string",
          "enum": ["python-uv", "python-pip", "java-maven", "java-gradle", "go", "node"]
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "container": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" },
        "command": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        }
      }
    },
    "pipeline": {
      "type": "object",
      "properties": {
        "test": { "$ref": "#/$defs/stageToggle" },
        "build": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "target": { "type": "string", "enum": ["package", "container"] },
            "dockerfileTemplate": { "type": "string" },
            "preCommands": { "$ref": "#/$defs/commands" },
            "commands": { "$ref": "#/$defs/commands" },
            "postCommands": { "$ref": "#/$defs/commands" }
          }
        },
        "publish": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "registry": { "type": "string" },
            "when": { "type": "string", "enum": ["tag", "branch", "always", "never"] },
            "preCommands": { "$ref": "#/$defs/commands" },
            "commands": { "$ref": "#/$defs/commands" },
            "postCommands": { "$ref": "#/$defs/commands" }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "sonar": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "projectKey": { "type": "string" }
          }
        }
      }
    },
    "deploy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "stageToggle": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "preCommands": { "$ref": "#/$defs/commands" },
        "commands": { "$ref": "#/$defs/commands" },
        "postCommands": { "$ref": "#/$defs/commands" }
      }
    },
    "commands": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    }
  }
}
