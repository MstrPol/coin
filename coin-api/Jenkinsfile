pipeline {
    agent any
    
    tools {
        go 'golang-1.25' // Подключение инструмента Go, настроенного в Jenkins
    }

    parameters {
        string(name: 'SOURCE_REGISTRY', defaultValue: 'registry.local', description: 'Registry for base images')
        string(name: 'TARGET_REGISTRY', defaultValue: 'registry.local:5000', description: 'Registry for output images')
        string(name: 'SOURCE_CRED_ID', defaultValue: 'source-registry-creds', description: 'Credentials for base images registry')
        string(name: 'TARGET_CRED_ID', defaultValue: 'target-registry-creds', description: 'Credentials for target images registry')
        string(name: 'GOPROXY', defaultValue: 'https://proxy.golang.org,direct', description: 'URL to Go Proxy/Nexus')
        string(name: 'GO_AUTH_CRED_ID', defaultValue: 'go-auth-token', description: 'Credentials ID for private Go modules (.netrc format)')
    }
    
    environment {
        APP_NAME = "coin-api"
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Test') {
            steps {
                script {
                    // Подключаем авторизацию для Go перед локальным тестированием
                    withEnv(["GOPROXY=${params.GOPROXY}", "GOINSECURE=*", "GIT_SSL_NO_VERIFY=true"]) {
                        withCredentials([string(credentialsId: params.GO_AUTH_CRED_ID, variable: 'GO_AUTH')]) {
                            echo "Running tests..."
                            sh '''
                                if [ -n "$GO_AUTH" ]; then
                                    echo "$GO_AUTH" > ~/.netrc
                                fi
                                go test ./...
                            '''
                        }
                    }
                }
            }
        }
        
        stage('Build & Push Image (BuildKit)') {
            steps {
                script {
                    // Инициализируем auth config для нескольких registries + токен для Go
                    withCredentials([
                        usernamePassword(credentialsId: params.SOURCE_CRED_ID, passwordVariable: 'SRC_PASS', usernameVariable: 'SRC_USER'),
                        usernamePassword(credentialsId: params.TARGET_CRED_ID, passwordVariable: 'TGT_PASS', usernameVariable: 'TGT_USER'),
                        string(credentialsId: params.GO_AUTH_CRED_ID, variable: 'GO_AUTH')
                    ]) {
                        // Формируем docker config.json средствами Groovy для авторизации
                        def dockerConfig = """
                        {
                            "auths": {
                                "${params.SOURCE_REGISTRY}": { "auth": "${"${SRC_USER}:${SRC_PASS}".bytes.encodeBase64().toString()}" },
                                "${params.TARGET_REGISTRY}": { "auth": "${"${TGT_USER}:${TGT_PASS}".bytes.encodeBase64().toString()}" }
                            }
                        }
                        """
                        writeFile file: '/tmp/config.json', text: dockerConfig
                        
                        def targetImage = "${params.TARGET_REGISTRY}/${env.APP_NAME}:${env.BUILD_ID}"
                        
                        // Запуск сборки через buildctl. Авторизация для Go передается как secret-mount.
                        sh """
                            export DOCKER_CONFIG=/tmp
                            buildctl build \\
                                --frontend dockerfile.v0 \\
                                --local context=. \\
                                --local dockerfile=. \\
                                --opt build-arg:REGISTRY=${params.SOURCE_REGISTRY}/ \\
                                --opt build-arg:GOPROXY=${params.GOPROXY} \\
                                --opt build-arg:GOINSECURE="*" \\
                                --opt build-arg:GIT_SSL_NO_VERIFY="true" \\
                                --secret id=go_auth,env=GO_AUTH \\
                                --output type=image,name=${targetImage},push=true
                        """
                    }
                }
            }
        }
    }
}
