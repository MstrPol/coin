{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/manifest.v1.schema.json",
  "title": "Coin resolved manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "manifestHash",
    "goldenPath",
    "runtime",
    "destinations",
    "build",
    "pipeline"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "goldenPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string" },
        "digest": { "type": "string" }
      }
    },
    "build": {
      "oneOf": [{ "$ref": "#/$defs/legacyBuild" }, { "$ref": "#/$defs/vNextBuild" }]
    },
    "parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameter" }
    },
    "deliverables": {
      "type": "array",
      "items": { "$ref": "#/$defs/deliverable" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "containerfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/namedContentRef" }
        }
      }
    },
    "destinations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imageRegistryPrefix", "buildCacheEnabled", "artifactRepositoryBase"],
      "properties": {
        "imageRegistryPrefix": { "type": "string", "minLength": 1 },
        "buildCacheEnabled": { "type": "boolean" },
        "artifactRepositoryBase": { "type": "string", "minLength": 1 }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "validateSchema": { "$ref": "#/$defs/contentRef" },
    "capabilities": {
      "type": "object"
    },
    "branching": {
      "type": "object",
      "required": ["name", "version", "branches"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "branches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "pattern", "versioning", "publish"],
            "properties": {
              "name": { "type": "string" },
              "pattern": { "type": "string" },
              "versioning": {
                "type": "object",
                "required": ["template"],
                "properties": {
                  "template": { "type": "string" }
                }
              },
              "publish": { "type": "boolean" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "buildkit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile", "targets", "containerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "containerfile": { "$ref": "#/$defs/contentRef" }
      }
    },
    "dockerfileEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "imageTarget": { "type": "string" },
        "testTarget": { "type": "string" }
      }
    },
    "legacyBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string", "enum": ["buildkit", "dockerfile"] },
        "buildkit": { "$ref": "#/$defs/buildkit" },
        "dockerfile": { "$ref": "#/$defs/dockerfileEngine" }
      }
    },
    "vNextBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/buildTarget" }
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "boolean", "number", "enum"] },
        "default": {},
        "required": { "type": "boolean" },
        "allowedValues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "buildTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "engine"],
      "properties": {
        "id": { "type": "string" },
        "engine": { "type": "string", "enum": ["buildkit", "dockerfile"] },
        "containerfile": { "type": "string" },
        "target": { "type": "string" },
        "dockerfile": { "type": "string" },
        "output": { "type": "string" }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "targetId"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "liquibase-image", "artifact"] },
        "targetId": { "type": "string" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repositorySuffix": { "type": "string" }
          }
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": { "type": "string" },
            "paths": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "namedContentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "sha256"],
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "when": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/stageStep" }
        }
      }
    },
    "stageStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "enum": ["run-target", "build-deliverable", "publish-deliverable"] },
        "targetId": { "type": "string" },
        "deliverableId": { "type": "string" }
      }
    }
  }
}
