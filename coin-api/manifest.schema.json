{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/manifest.v1.schema.json",
  "title": "Coin resolved manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "manifestHash",
    "goldenPath",
    "runtime",
    "build",
    "pipeline"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "goldenPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string" },
        "digest": { "type": "string" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string", "enum": ["buildkit", "dockerfile"] },
        "buildkit": { "$ref": "#/$defs/buildkit" },
        "dockerfile": { "$ref": "#/$defs/dockerfileEngine" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "validateSchema": { "$ref": "#/$defs/contentRef" },
    "capabilities": {
      "type": "object"
    },
    "branching": {
      "type": "object",
      "required": ["name", "version", "branches"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "branches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "pattern", "versioning", "publish"],
            "properties": {
              "name": { "type": "string" },
              "pattern": { "type": "string" },
              "versioning": {
                "type": "object",
                "required": ["template"],
                "properties": {
                  "template": { "type": "string" }
                }
              },
              "publish": { "type": "boolean" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "buildkit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile", "targets", "containerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "cacheRef": { "type": "string" },
        "containerfile": { "$ref": "#/$defs/contentRef" }
      }
    },
    "dockerfileEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "imageTarget": { "type": "string" },
        "testTarget": { "type": "string" },
        "cacheRef": { "type": "string" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "when": { "type": "string" }
      }
    }
  }
}
