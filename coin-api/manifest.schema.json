{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/manifest.v1.schema.json",
  "title": "Coin resolved manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "manifestHash",
    "goldenPath",
    "executor",
    "runtime",
    "pipeline",
    "orchestration"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "goldenPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "url", "sha256"],
      "properties": {
        "version": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string" },
        "digest": { "type": "string" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "orchestration": { "$ref": "#/$defs/contentRef" },
    "validateSchema": { "$ref": "#/$defs/contentRef" },
    "dockerfileTemplate": { "$ref": "#/$defs/contentRef" },
    "credentials": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "script"],
      "properties": {
        "name": { "type": "string" },
        "when": { "type": "string" },
        "script": { "$ref": "#/$defs/contentRef" }
      }
    }
  }
}
