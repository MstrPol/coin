{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/manifest.v1.schema.json",
  "title": "Coin resolved manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "manifestHash",
    "goldenPath",
    "executor",
    "runtime",
    "build",
    "pipeline"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "goldenPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "url", "sha256"],
      "properties": {
        "version": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string" },
        "digest": { "type": "string" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string", "enum": ["buildkit", "buildpack", "dockerfile"] },
        "buildkit": { "$ref": "#/$defs/buildkit" },
        "buildpack": { "$ref": "#/$defs/buildpack" },
        "dockerfile": { "$ref": "#/$defs/dockerfileEngine" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "validateSchema": { "$ref": "#/$defs/contentRef" },
    "credentials": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "capabilities": {
      "type": "object"
    },
    "lib": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "branching": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "trunk": { "type": "object" },
        "branchTypes": { "type": "array", "items": { "type": "string" } },
        "versioning": { "type": "object" },
        "publish": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "buildkit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile", "targets", "containerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "cacheRef": { "type": "string" },
        "containerfile": { "$ref": "#/$defs/contentRef" }
      }
    },
    "buildpack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builder"],
      "properties": {
        "builder": { "type": "string", "minLength": 1 },
        "runImage": { "type": "string" },
        "cacheRef": { "type": "string" }
      }
    },
    "dockerfileEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile", "containerfile"],
      "properties": {
        "dockerfile": { "type": "string", "minLength": 1 },
        "imageTarget": { "type": "string" },
        "testTarget": { "type": "string" },
        "cacheRef": { "type": "string" },
        "containerfile": { "$ref": "#/$defs/contentRef" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "when": { "type": "string" }
      }
    }
  }
}
