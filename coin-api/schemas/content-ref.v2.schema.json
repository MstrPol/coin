{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/content-ref.v2.schema.json",
  "title": "Component content_ref v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "manifest": {
      "type": "object",
      "description": "Type-specific resolve subset (build, pipeline, branching rules, …)"
    }
  },
  "anyOf": [
    { "required": ["package"] },
    { "required": ["manifest"] }
  ]
}
