{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schema/config.v2.schema.json",
  "title": "Coin product config v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["coin", "project", "jenkins"],
  "properties": {
    "coin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goldenPath", "version"],
      "properties": {
        "goldenPath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Golden path name, e.g. go-app"
        },
        "version": {
          "type": "string",
          "pattern": "^([=~^\\*]|\\d)[0-9A-Za-z.+\\-*]*$",
          "description": "Semver GP pin: =1.0.0 (exact), ~1.0.0 (patch), ^1.0.0 (minor), * (latest stable)"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "groupId": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        }
      }
    },
    "jenkins": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credentials"],
      "properties": {
        "stack": {
          "type": "string"
        },
        "runtime": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "required": ["docker"],
          "properties": {
            "docker": {
              "type": "string",
              "minLength": 1
            },
            "qgm": {
              "type": "string"
            },
            "nexus": {
              "type": "string"
            }
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": { "$ref": "#/$defs/stage" },
        "build": { "$ref": "#/$defs/stage" },
        "publish": { "$ref": "#/$defs/stage" }
      }
    },
    "rn": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceUrl": { "type": "string" },
        "codeRepository": { "type": "string" }
      }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "preCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "postCommands": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
