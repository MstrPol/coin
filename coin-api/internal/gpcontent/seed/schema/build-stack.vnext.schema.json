{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coin.local/schemas/build-stack.vnext.schema.json",
  "title": "Build Stack vNext",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "build", "deliverables", "pipeline", "artifacts"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameter" },
      "default": []
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/buildTarget" }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/deliverable" }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validateSchema"],
      "properties": {
        "validateSchema": { "type": "string", "minLength": 1 },
        "containerfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/containerfile" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "type": { "type": "string", "enum": ["string", "boolean", "number", "enum"] },
        "default": {},
        "required": { "type": "boolean", "default": false },
        "allowedValues": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "enum" } }, "required": ["type"] },
          "then": { "required": ["allowedValues"] }
        }
      ]
    },
    "buildTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "engine"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "engine": { "type": "string", "enum": ["buildkit", "dockerfile"] },
        "containerfile": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "dockerfile": { "type": "string", "minLength": 1 },
        "output": { "type": "string", "enum": ["image", "artifact", "test", "validate"] }
      },
      "allOf": [
        {
          "if": { "properties": { "engine": { "const": "buildkit" } }, "required": ["engine"] },
          "then": { "required": ["containerfile", "target"] }
        },
        {
          "if": { "properties": { "engine": { "const": "dockerfile" } }, "required": ["engine"] },
          "then": { "required": ["dockerfile"] }
        }
      ]
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "targetId"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "type": { "type": "string", "enum": ["image", "liquibase-image", "artifact"] },
        "targetId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "repositorySuffix": { "type": "string" } }
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": { "type": "string", "enum": ["zip", "tar"] },
            "paths": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          }
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "steps"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stageStep" }
        }
      }
    },
    "stageStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "enum": ["run-target", "build-deliverable", "publish-deliverable"] },
        "targetId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "deliverableId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
      }
    },
    "containerfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
