FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /coin-api ./cmd/coin-api

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /coin-api /usr/local/bin/coin-api
EXPOSE 8090
ENTRYPOINT ["coin-api"]
